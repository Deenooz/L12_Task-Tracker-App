<!DOCTYPE html>
<html>
<head>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<%- include('partials/header') %>

<div class="container mt-4 text-center">

<h1>My Task Tracker</h1>

<div class="row mt-4">

<!-- Upcoming -->
<div class="col-md-4">
<div class="card">
<div class="card-header bg-dark text-white">Upcoming Tasks</div>
<ul class="list-group">
<% upcoming.forEach(t => { %>
<li class="list-group-item"><%= t.name %></li>
<% }) %>
</ul>
</div>
</div>

<!-- In Progress -->
<div class="col-md-4">
<div class="card">
<div class="card-header bg-dark text-white">In Progress</div>
<ul class="list-group">
<% progress.forEach(t => { %>
<li class="list-group-item"><%= t.name %></li>
<% }) %>
</ul>
</div>
</div>

<!-- Completed / Missed -->
<div class="col-md-4">
<div class="card">
<div class="card-header bg-dark text-white">Completed / Missed</div>

<div class="p-2">

<b>Completed</b>
<ul class="list-group mb-2">
<% completed.forEach(t => { %>
<li class="list-group-item"><%= t.name %></li>
<% }) %>
</ul>

<b>Missed</b>
<ul class="list-group">
<% missed.forEach(t => { %>
<li class="list-group-item"><%= t.name %></li>
<% }) %>
</ul>

</div>

</div>
</div>

</div>

<div class="mt-4">
<a href="/tracking" class="btn btn-primary">View Full List</a>
<a href="/add" class="btn btn-success">Add Task</a>
</div>

</div>

</body>
</html>