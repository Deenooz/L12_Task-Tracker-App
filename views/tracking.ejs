<!DOCTYPE html>
<html>
<head>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<%- include('partials/header') %>

<div class="container mt-4">

<h2 class="text-center">Tracking List</h2>

<form method="GET" class="d-flex mb-3">
    <input 
        type="text"
        name="search"
        value="<%= search %>"
        placeholder="Search category or task (e.g. School, Gaming)"
        class="form-control me-2"
    >
    <button class="btn btn-primary">Search</button>
    <a href="/tracking" class="btn btn-secondary ms-2">Reset</a>
</form>

<table class="table table-bordered">

<tr>
<th>ID</th>
<th>Task Name</th>
<th>Category</th>
<th>Status</th>
<th>Actions</th>
</tr>

<% tasks.forEach(t => { %>
<tr>
<td><%= t.id %></td>
<td><%= t.name %></td>
<td><%= t.category %></td>
<td><%= t.status %></td>

<td>
<a href="/edit/<%= t.id %>" class="btn btn-warning btn-sm">Edit</a>

<form action="/delete/<%= t.id %>" method="POST" style="display:inline;">
<button class="btn btn-danger btn-sm">Delete</button>
</form>
</td>

</tr>
<% }) %>

</table>

</div>

</body>
</html>